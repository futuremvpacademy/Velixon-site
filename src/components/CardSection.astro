---
interface CardItem {
  title: string;
  description: string;
  meta?: string;
  outcome?: string;
}

interface Props {
  eyebrow: string;
  title: string;
  description?: string;
  items: CardItem[];
}

const { eyebrow, title, description, items } = Astro.props;
---

<section class="page-section">
  <div class="container">
    <div class="section-intro">
      <p class="eyebrow">{eyebrow}</p>
      <h2>{title}</h2>
      {description && <p>{description}</p>}
    </div>

    <div class="detail-grid">
      {
        items.map((item) => (
          <article class="detail-card">
            {item.meta && <p class="detail-meta">{item.meta}</p>}
            <h3>{item.title}</h3>
            <p>{item.description}</p>
            {item.outcome && <p class="detail-outcome">{item.outcome}</p>}
          </article>
        ))
      }
    </div>
  </div>
</section>
