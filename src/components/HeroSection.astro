---
interface Metric {
  value: string;
  label: string;
}

interface HeroPreview {
  label: string;
  title: string;
  description: string;
  metrics: Metric[];
  layers: string[];
}

interface Props {
  eyebrow: string;
  headline: string;
  subheadline: string;
  cta: string;
  ctaHref: string;
  secondaryCta: string;
  secondaryCtaHref: string;
  heroPreview: HeroPreview;
  logo: string;
}

const {
  eyebrow,
  headline,
  subheadline,
  cta,
  ctaHref,
  secondaryCta,
  secondaryCtaHref,
  heroPreview,
  logo
} = Astro.props;

const headlineHtml = headline.replace(/\n/g, "<br />");
const subheadlineHtml = subheadline.replace(/\n/g, "<br />");
---

<section class="hero" id="top">
  <div class="hero-orb hero-orb-one" aria-hidden="true"></div>
  <div class="hero-orb hero-orb-two" aria-hidden="true"></div>
  <div class="hero-orb hero-orb-three" aria-hidden="true"></div>
  <div class="container hero-grid">
    <div class="hero-copy hero-copy-minimal">
      <div class="tech-label">{eyebrow}</div>
      <h1 set:html={headlineHtml}></h1>
      <p class="hero-text hero-lead" set:html={subheadlineHtml}></p>
      <div class="hero-actions">
        <a class="button" href={ctaHref}>{cta}</a>
        <a class="button button-secondary" href={secondaryCtaHref}>{secondaryCta}</a>
      </div>
    </div>

    <div class="hero-panel hero-panel-minimal" aria-label="Velixon preview">
      <div class="preview-shell">
        <div class="preview-topbar">
          <div class="preview-dots">
            <span></span>
            <span></span>
            <span></span>
          </div>
          <div class="preview-pill">{heroPreview.label}</div>
        </div>

        <div class="preview-stage">
          <div class="preview-brand">
            <img src={logo} alt="" aria-hidden="true" />
            <span>Velixon</span>
          </div>

          <div class="preview-grid">
            <div class="preview-main-card">
              <p class="preview-kicker">Premium launch system</p>
              <h2>{heroPreview.title}</h2>
              <p>{heroPreview.description}</p>
            </div>

            <div class="preview-side-card">
              {heroPreview.metrics.map((metric) => (
                <div class="mini-stat">
                  <strong>{metric.value}</strong>
                  <span>{metric.label}</span>
                </div>
              ))}
            </div>
          </div>

          <div class="preview-footer">
            {heroPreview.layers.map((item) => <span>{item}</span>)}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
