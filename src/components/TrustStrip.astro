---
interface Props {
  items: {
    title: string;
    detail: string;
  }[];
}

const { items } = Astro.props;
---

<section class="trust-strip" aria-label="Trust indicators">
  <div class="container trust-grid">
    {
      items.map((item) => (
        <article class="trust-item">
          <span class="trust-accent" aria-hidden="true"></span>
          <h3>{item.title}</h3>
          <p>{item.detail}</p>
        </article>
      ))
    }
  </div>
</section>
