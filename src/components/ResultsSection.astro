---
interface Results {
  eyebrow: string;
  title: string;
  items: {
    title: string;
    detail: string;
  }[];
}

interface Props {
  results: Results;
}

const { results } = Astro.props;
---

<section class="results-section">
  <div class="container">
    <div class="section-intro">
      <p class="eyebrow">{results.eyebrow}</p>
      <h2>{results.title}</h2>
    </div>

    <div class="results-grid">
      {
        results.items.map((item) => (
          <article class="result-card">
            <span class="result-mark" aria-hidden="true"></span>
            <h3>{item.title}</h3>
            <p>{item.detail}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
