---
interface Props {
  intro: {
    logo: string;
    headline: string;
    helper: string;
    video: string;
  };
}

const { intro } = Astro.props;
---

<div
  class="intro-overlay"
  data-intro-overlay
  data-video={intro.video}
  data-session-key="velixon-intro-complete"
  aria-hidden="true"
>
  <div class="intro-overlay-inner" data-intro-prompt>
    <img class="intro-logo" src={intro.logo} alt="Velixon logo" />
    <p class="intro-headline">{intro.headline}</p>
    <p class="intro-helper">{intro.helper}</p>
  </div>

  <div class="intro-video-wrap" data-intro-video-wrap>
    <video
      class="intro-video"
      data-intro-video
      playsinline
      preload="metadata"
      muted
    >
      <source src={intro.video} type="video/mp4" />
    </video>
  </div>
</div>

<script is:inline>
  (() => {
    const overlay = document.querySelector("[data-intro-overlay]");
    if (!overlay) return;

    const prompt = overlay.querySelector("[data-intro-prompt]");
    const videoWrap = overlay.querySelector("[data-intro-video-wrap]");
    const video = overlay.querySelector("[data-intro-video]");
    const videoPath = overlay.getAttribute("data-video") || "";
    const sessionKey = overlay.getAttribute("data-session-key") || "velixon-intro-complete";
    const fallbackDelay = 2250;
    let hasStarted = false;
    let hasRevealed = false;
    let fallbackTimer;

    const logState = (message) => {
      console.debug(`[Velixon Intro] ${message}`);
    };

    const finishIntro = () => {
      if (hasRevealed) return;
      hasRevealed = true;
      window.clearTimeout(fallbackTimer);
      logState("homepage revealed");
      sessionStorage.setItem(sessionKey, "true");
      overlay.classList.add("is-complete");
      document.body.classList.remove("intro-locked");
      window.setTimeout(() => {
        overlay.remove();
      }, 900);
    };

    const startCssFallback = () => {
      overlay.classList.add("is-fallback");
      videoWrap?.classList.remove("is-visible");
      window.setTimeout(() => {
        finishIntro();
      }, 900);
    };

    if (sessionStorage.getItem(sessionKey) === "true") {
      document.body.classList.remove("intro-locked");
      overlay.remove();
      return;
    }

    logState("intro shown");
    document.body.classList.add("intro-locked");

    const startIntro = async () => {
      if (hasStarted) return;
      hasStarted = true;
      logState("user clicked");

      overlay.classList.add("is-starting");
      prompt?.classList.add("is-hidden");
      fallbackTimer = window.setTimeout(() => {
        logState("video failed");
        startCssFallback();
      }, fallbackDelay);

      if (!video || !videoPath) {
        logState("video failed");
        startCssFallback();
        return;
      }

      const onVideoStarted = () => {
        logState("video started");
      };

      const onVideoEnded = () => {
        logState("video ended");
        finishIntro();
      };

      const onVideoFailed = () => {
        logState("video failed");
        startCssFallback();
      };

      video.addEventListener("playing", onVideoStarted, { once: true });
      video.addEventListener("ended", onVideoEnded, { once: true });
      video.addEventListener("error", onVideoFailed, { once: true });
      video.addEventListener("stalled", onVideoFailed, { once: true });
      video.addEventListener("abort", onVideoFailed, { once: true });

      videoWrap?.classList.add("is-visible");
      video.load();

      try {
        await video.play();
      } catch {
        logState("video failed");
        startCssFallback();
      }
    };

    overlay.addEventListener("click", startIntro, { once: true });
    overlay.addEventListener(
      "touchend",
      () => {
        if (!hasStarted) startIntro();
      },
      { once: true }
    );
  })();
</script>
