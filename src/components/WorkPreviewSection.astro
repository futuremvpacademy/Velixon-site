---
interface Props {
  workPreview: {
    eyebrow: string;
    title: string;
    description: string;
    cardTag: string;
    cardAccent: string;
    cardTitle: string;
    cardDescription: string;
  };
  ctaLabel?: string;
  ctaHref?: string;
}

const { workPreview, ctaLabel, ctaHref } = Astro.props;
---

<section class="work-preview-section">
  <div class="container">
    <div class="section-intro">
      <p class="eyebrow">{workPreview.eyebrow}</p>
      <h2>{workPreview.title}</h2>
      <p>{workPreview.description}</p>
    </div>

    <div class="work-preview-grid">
      <article class="work-preview-card work-preview-card-showcase">
        <div class="work-preview-top">
          <span class="work-preview-tag">{workPreview.cardTag}</span>
          <span class="work-preview-accent">{workPreview.cardAccent}</span>
        </div>

        <h3>{workPreview.cardTitle}</h3>

        <div class="work-preview-image-shell work-preview-compare" data-compare-root>
          <div
            class="work-preview-compare-panel work-preview-compare-after"
            style={`background-image: url('/images/prism-before-after.png');`}
            aria-hidden="true"
          ></div>
          <div
            class="work-preview-compare-panel work-preview-compare-before"
            data-compare-before
            style={`background-image: url('/images/prism-before-after.png');`}
            aria-hidden="true"
          ></div>
          <div class="work-preview-compare-divider" data-compare-divider aria-hidden="true">
            <span></span>
          </div>
          <div class="work-preview-compare-label work-preview-compare-label-before">Before</div>
          <div class="work-preview-compare-label work-preview-compare-label-after">After</div>
          <input
            class="work-preview-compare-range"
            data-compare-range
            type="range"
            min="0"
            max="100"
            value="50"
            aria-label="Compare the before and after website redesign"
          />
          <div class="work-preview-image-overlay"></div>
        </div>

        <p>{workPreview.cardDescription}</p>
      </article>
    </div>

    {ctaLabel && ctaHref && (
      <div class="section-link-row">
        <a class="button button-secondary" href={ctaHref}>{ctaLabel}</a>
      </div>
    )}
  </div>
</section>
