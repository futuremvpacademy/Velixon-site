---
interface PricingClarity {
  eyebrow: string;
  title: string;
  description: string;
  bullets: string[];
}

interface Props {
  pricingClarity: PricingClarity;
}

const { pricingClarity } = Astro.props;
---

<section class="pricing-clarity-section" id="pricing">
  <div class="container">
    <div class="pricing-clarity-shell">
      <div class="section-intro">
        <p class="eyebrow">{pricingClarity.eyebrow}</p>
        <h2>{pricingClarity.title}</h2>
        <p>{pricingClarity.description}</p>
      </div>

      <div class="pricing-clarity-points">
        {pricingClarity.bullets.map((bullet) => <span>{bullet}</span>)}
      </div>
    </div>
  </div>
</section>
