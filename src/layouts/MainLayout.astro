---
import "../styles/global.css";
import Footer from "../components/Footer.astro";
import { siteContent } from "../data/site";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const { logo, companyName, footer, footerNav, contactInfo } = siteContent;
const siteUrl = "https://velixon.net";
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="google-site-verification" content="dGkUQvJiuJnXuZ91zKH9JoP3fADKym0_TzAcCa90PtY" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-B68W7DF2RB"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-B68W7DF2RB");
    </script>
  </head>
  <body>
    <div class="site-shell">
      <div class="site-content">
        <slot />
      </div>
      <Footer
        logo={logo}
        companyName={companyName}
        nav={footerNav}
        footer={footer}
        phone={contactInfo.phone}
      />
    </div>
    <script is:inline>
      (() => {
        const setupCompare = () => {
          document.querySelectorAll("[data-compare-root]").forEach((root) => {
            const range = root.querySelector("[data-compare-range]");
            const before = root.querySelector("[data-compare-before]");
            const divider = root.querySelector("[data-compare-divider]");
            if (!range || !before || !divider) return;

            const update = (value) => {
              const percent = `${value}%`;
              before.style.clipPath = `inset(0 ${100 - value}% 0 0)`;
              divider.style.left = percent;
              root.style.setProperty("--compare-position", percent);
            };

            update(Number(range.value || 50));
            range.addEventListener("input", () => update(Number(range.value)));
          });
        };
        setupCompare();
      })();
    </script>
  </body>
</html>
