---
import MainLayout from "../layouts/MainLayout.astro";
import { siteContent } from "../data/site";

const { companyName, logo } = siteContent;
const reviews = [
  {
    name: "Chiggy Combs",
    quote: "Working with Velixon was one of the best decisions I made for my business. They built me a clean, professional website...",
    stars: 5,
    avatarSrc: "/images/reviews/review-1.png",
    angle: 280
  },
  {
    name: "Giada Ferrazzano",
    quote: "Velixon did an amazing job creating a website for my How to Be a Latina 101 book. From the beginning, they really...",
    stars: 5,
    avatarSrc: "/images/reviews/review-2.png",
    angle: 320
  },
  {
    name: "Mighty Movers",
    quote: "Velixon did a great job helping us through our rebrand at Mighty Movers. They updated our website, improved the overall...",
    stars: 5,
    avatarSrc: "/images/reviews/review-3.png",
    angle: 240
  },
  {
    name: "Ready Relocation",
    quote: "Velixon did a wonderful job creating our logo for Ready Relocation. They really understood the vision and delivered...",
    stars: 5,
    avatarSrc: "/images/reviews/review-4.png",
    angle: 40
  },
  {
    name: "Geovanny Ibarra",
    quote: "Me hicieron un trabajo excelente y todo quedó bien con mi página web",
    stars: 5,
    avatarSrc: "/images/reviews/review-5.png",
    angle: 200
  },
  {
    name: "Frontier Fence Llc",
    quote:
      "The customer service was exemplary from beginning to end. The team demonstrated utmost professionalism throughout the entire process. I would highly recommend their services to any prospective cli",
    stars: 5,
    avatarSrc: "/images/reviews/review-6.png",
    angle: 80
  },
  {
    name: "Audrey Earnshaw",
    quote:
      "Thanks for helping me design my website! I have seen my sales increase by 25% so far and I expect that number will increase over time!",
    stars: 5,
    avatarSrc: "/images/reviews/review-7.png",
    angle: 120
  },
  {
    name: "Jorge Carrizosa",
    quote: "Increíble la atención del lugar. Sin duda muy buena experiencia con la empresa y muy recomendable.",
    stars: 4,
    avatarSrc: "/images/reviews/review-8.png",
    angle: 160
  },
  {
    name: "Future MVP Soccer Academy",
    quote:
      "Velixon did an incredible job building our website for Future MVP Soccer Academy. They created a clean, professional...",
    stars: 5,
    avatarSrc: "/images/reviews/review-9.png",
    angle: 0
  }
];
---

<MainLayout
  title="Leave a Review | Velixon"
  description="Leave a quick Google review for Velixon. Your feedback helps our business grow and helps others trust our services."
>
  <style is:global>
    .review-page {
      flex: 1;
      min-height: 0;
      background:
        radial-gradient(circle at 50% 7%, rgba(154, 140, 255, 0.13), transparent 26%),
        radial-gradient(circle at 50% 54%, rgba(154, 140, 255, 0.09), transparent 36%),
        #050505;
    }

    .review-hero {
      position: relative;
      min-height: 100vh;
      padding: 1rem 0 clamp(1.4rem, 2.6vw, 2rem);
      overflow: hidden;
    }

    .review-shell {
      position: relative;
      z-index: 1;
      display: flex;
      justify-content: center;
      width: 100%;
      max-width: 1368px;
    }

    .review-showcase {
      position: relative;
      width: min(100%, 1368px);
      min-height: min(88vw, 1120px);
      display: grid;
      place-items: center;
      isolation: isolate;
    }

    .review-showcase::before {
      content: "";
      position: absolute;
      inset: 8% 10% 7%;
      border: 1px solid rgba(185, 178, 217, 0.14);
      border-radius: 54px;
      background:
        radial-gradient(circle at 49% 27%, rgba(154, 140, 255, 0.08), transparent 22%),
        linear-gradient(180deg, rgba(18, 18, 22, 0.58), rgba(9, 9, 11, 0.38));
      box-shadow:
        inset 0 0 84px rgba(154, 140, 255, 0.025),
        0 0 46px rgba(0, 0, 0, 0.34);
      pointer-events: none;
      z-index: -3;
    }

    .review-showcase::after {
      content: "";
      position: absolute;
      inset: 17% 24% 22%;
      border-radius: 999px;
      background: radial-gradient(circle, rgba(154, 140, 255, 0.09), transparent 62%);
      filter: blur(18px);
      opacity: 0.5;
      pointer-events: none;
      z-index: -2;
    }

    .review-panel {
      position: absolute;
      inset: 12% 6% 5%;
      border-radius: 999px;
      background:
        radial-gradient(circle at 50% 6%, rgba(154, 140, 255, 0.2), transparent 9%),
        conic-gradient(
          from -18deg,
          transparent 0deg,
          rgba(154, 140, 255, 0.18) 16deg,
          rgba(190, 178, 255, 0.86) 29deg,
          rgba(154, 140, 255, 0.22) 44deg,
          transparent 64deg,
          transparent 109deg,
          rgba(154, 140, 255, 0.18) 126deg,
          rgba(190, 178, 255, 0.9) 144deg,
          rgba(154, 140, 255, 0.22) 158deg,
          transparent 178deg,
          transparent 202deg,
          rgba(154, 140, 255, 0.16) 222deg,
          rgba(190, 178, 255, 0.85) 238deg,
          rgba(154, 140, 255, 0.2) 252deg,
          transparent 274deg,
          transparent 309deg,
          rgba(154, 140, 255, 0.18) 327deg,
          rgba(190, 178, 255, 0.86) 344deg,
          transparent 360deg
        );
      filter: drop-shadow(0 0 12px rgba(154, 140, 255, 0.56));
      opacity: 0.95;
      pointer-events: none;
      z-index: -1;
    }

    .review-panel::before {
      content: "";
      position: absolute;
      inset: 8px;
      border-radius: inherit;
      background: #050505;
    }

    .review-panel::after {
      content: "";
      position: absolute;
      inset: -5px;
      border-radius: inherit;
      background:
        radial-gradient(circle at 16% 29%, rgba(154, 140, 255, 0.62), transparent 4%),
        radial-gradient(circle at 31% 7%, rgba(199, 190, 255, 0.64), transparent 3%),
        radial-gradient(circle at 67% 7%, rgba(199, 190, 255, 0.64), transparent 3%),
        radial-gradient(circle at 86% 29%, rgba(154, 140, 255, 0.62), transparent 4%),
        radial-gradient(circle at 92% 47%, rgba(154, 140, 255, 0.62), transparent 4%),
        radial-gradient(circle at 87% 67%, rgba(154, 140, 255, 0.62), transparent 4%),
        radial-gradient(circle at 67% 96%, rgba(199, 190, 255, 0.64), transparent 3%),
        radial-gradient(circle at 31% 96%, rgba(199, 190, 255, 0.64), transparent 3%),
        radial-gradient(circle at 12% 68%, rgba(154, 140, 255, 0.62), transparent 4%),
        radial-gradient(circle at 8% 47%, rgba(154, 140, 255, 0.62), transparent 4%);
      filter: blur(1px);
    }

    .review-orbit-line {
      position: absolute;
      inset: 12% 6% 5%;
      pointer-events: none;
      z-index: 0;
    }

    .review-orbit-line span {
      position: absolute;
      top: 50%;
      left: 50%;
      width: 10px;
      height: 10px;
      margin: -5px;
      border-radius: 999px;
      background: #c8bbff;
      box-shadow:
        0 0 10px rgba(199, 190, 255, 0.95),
        0 0 24px rgba(154, 140, 255, 0.65);
      transform:
        rotate(calc(var(--dot-index) * 30deg))
        translateY(clamp(-440px, -32vw, -258px))
        rotate(calc(var(--dot-index) * -30deg));
    }

    .review-testimonials {
      position: absolute;
      inset: 0;
      pointer-events: none;
      z-index: 3;
      animation: reviewFerrisWheel 72s linear infinite;
    }

    .review-mini-card {
      --review-radius: clamp(382px, 35.4vw, 470px);
      position: absolute;
      top: 50%;
      left: 50%;
      width: clamp(232px, 19.2vw, 282px);
      pointer-events: auto;
      transform:
        translate(-50%, -50%)
        rotate(var(--review-angle))
        translateY(calc(var(--review-radius) * -1))
        rotate(calc(var(--review-angle) * -1));
      transform-origin: center;
    }

    .review-mini-card-inner {
      min-height: 104px;
      display: grid;
      grid-template-columns: 46px 1fr;
      gap: 0.72rem;
      padding: 0.8rem 0.88rem 0.86rem;
      border: 1px solid rgba(190, 178, 217, 0.2);
      border-radius: 20px;
      background: linear-gradient(180deg, rgba(19, 19, 23, 0.98), rgba(13, 13, 16, 0.98));
      box-shadow:
        0 18px 34px rgba(0, 0, 0, 0.42),
        inset 0 1px 0 rgba(255, 255, 255, 0.03);
      animation: reviewFerrisCard 72s linear infinite;
      transform-origin: center;
    }

    .review-mini-avatar {
      width: 46px;
      height: 46px;
      overflow: hidden;
      border: 1px solid rgba(255, 255, 255, 0.14);
      border-radius: 999px;
      background: #1d1d21;
    }

    .review-mini-avatar img {
      width: 1300px;
      max-width: none;
      height: auto;
      transform: translate(-9px, -18px) scale(0.81);
      transform-origin: top left;
    }

    .review-mini-body {
      min-width: 0;
    }

    .review-mini-topline {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 0.7rem;
    }

    .review-mini-card h2 {
      margin: 0;
      color: #ffffff;
      font-family: var(--font-body);
      font-size: clamp(0.82rem, 0.98vw, 0.96rem);
      line-height: 1.18;
      font-weight: 700;
      letter-spacing: -0.03em;
    }

    .review-google-mark {
      width: 19px;
      height: 19px;
      flex: 0 0 19px;
    }

    .review-google-mark svg,
    .review-button-google svg {
      width: 100%;
      height: 100%;
      display: block;
    }

    .review-mini-stars {
      display: inline-flex;
      align-items: center;
      gap: 0.02em;
      margin-top: 0.18rem;
      color: #ffc400;
      font-size: 0.92rem;
      line-height: 1;
      letter-spacing: 0.04em;
    }

    .review-star-muted {
      color: rgba(255, 255, 255, 0.72);
    }

    .review-mini-card p {
      margin: 0.52rem 0 0;
      color: rgba(255, 255, 255, 0.88);
      font-size: clamp(0.7rem, 0.78vw, 0.8rem);
      line-height: 1.24;
      letter-spacing: -0.02em;
    }

    .review-card {
      position: relative;
      width: min(100%, 450px);
      display: grid;
      justify-items: center;
      text-align: center;
      gap: 1.15rem;
      margin-top: 2.6rem;
      padding: 0;
      background: transparent;
      border: 0;
      box-shadow: none;
      z-index: 5;
    }

    .review-logo {
      width: 170px;
      height: auto;
      margin-bottom: -0.45rem;
      filter:
        drop-shadow(0 0 18px rgba(203, 189, 242, 0.24))
        drop-shadow(0 0 42px rgba(203, 189, 242, 0.15));
    }

    .review-brand-label {
      margin: 0;
      color: #a899ff;
      font-family: var(--font-heading);
      font-size: 1.16rem;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }

    .review-stars {
      display: inline-flex;
      align-items: center;
      gap: 0.42rem;
      color: #a997ff;
      font-size: clamp(1.5rem, 2.65vw, 2.08rem);
      letter-spacing: 0.08em;
      line-height: 0.9;
      text-shadow:
        0 0 18px rgba(154, 140, 255, 0.26),
        0 0 34px rgba(154, 140, 255, 0.12);
    }

    .review-card h1 {
      max-width: 9.4ch;
      margin: 0.65rem 0 0;
      font-family: var(--font-heading);
      font-size: clamp(3rem, 4.95vw, 4.65rem);
      line-height: 0.9;
      font-weight: 700;
      letter-spacing: -0.07em;
      text-wrap: balance;
    }

    .review-card h1 span {
      display: block;
    }

    .review-text {
      max-width: 460px;
      margin: 0.35rem auto 0;
      color: rgba(255, 255, 255, 0.66);
      font-size: clamp(0.88rem, 1.02vw, 0.98rem);
      line-height: 1.52;
      letter-spacing: -0.03em;
      text-wrap: pretty;
    }

    .review-actions {
      display: grid;
      justify-items: center;
      gap: 0.75rem;
      width: 100%;
      padding-top: 0.45rem;
    }

    .review-button {
      min-width: 292px;
      min-height: 56px;
      gap: 0.78rem;
      border-radius: 10px;
      background: linear-gradient(135deg, #c7bbff 0%, #8d7aff 100%);
      color: #050505;
      font-size: 1rem;
      font-weight: 800;
      box-shadow:
        0 22px 44px rgba(0, 0, 0, 0.34),
        0 0 30px rgba(154, 140, 255, 0.28);
    }

    .review-button-google {
      width: 26px;
      height: 26px;
      flex: 0 0 26px;
    }

    .review-helper {
      margin: 0;
      color: rgba(255, 255, 255, 0.6);
      font-size: 0.8rem;
      line-height: 1.5;
    }

    .review-secondary-link {
      color: rgba(255, 255, 255, 0.7);
      font-size: 0.8rem;
      text-decoration: underline;
      text-decoration-color: rgba(255, 255, 255, 0.42);
      text-underline-offset: 0.2em;
    }

    .review-secondary-link:hover {
      color: var(--primary-bright);
      text-decoration-color: rgba(154, 140, 255, 0.5);
    }

    @keyframes reviewFerrisWheel {
      to {
        transform: rotate(360deg);
      }
    }

    @keyframes reviewFerrisCard {
      to {
        transform: rotate(-360deg);
      }
    }

    @media (max-width: 960px) {
      .review-hero {
        min-height: auto;
        padding: 1.4rem 0 4rem;
      }

      .review-showcase {
        min-height: 1120px;
      }

      .review-showcase::before,
      .review-panel,
      .review-orbit-line {
        inset-inline: 2%;
      }

      .review-mini-card {
        --review-radius: clamp(330px, 40vw, 405px);
        width: 220px;
      }

      .review-mini-card-inner {
        min-height: 104px;
        grid-template-columns: 44px 1fr;
        gap: 0.68rem;
        padding: 0.78rem;
      }

      .review-mini-avatar {
        width: 44px;
        height: 44px;
      }

      .review-mini-avatar img {
        transform: translate(-9px, -18px) scale(0.78);
      }

      .review-mini-card p {
        font-size: 0.82rem;
      }
    }

    @media (max-width: 640px) {
      .review-hero {
        padding: 1.2rem 0 3rem;
        overflow: visible;
      }

      .review-showcase {
        min-height: auto;
        display: flex;
        flex-direction: column;
        gap: 1.2rem;
        padding: 0;
      }

      .review-showcase::before,
      .review-showcase::after,
      .review-panel,
      .review-orbit-line {
        display: none;
      }

      .review-testimonials {
        position: relative;
        inset: auto;
        width: 100%;
        display: grid;
        gap: 0.85rem;
        order: 2;
        animation: none;
      }

      .review-mini-card {
        position: relative;
        top: auto;
        left: auto;
        width: 100%;
        transform: none;
      }

      .review-mini-card-inner {
        animation: none;
      }

      .review-card {
        width: 100%;
        order: 1;
        gap: 0.95rem;
        margin-top: 0;
      }

      .review-card h1 {
        max-width: none;
        font-size: clamp(2.55rem, 12vw, 3.5rem);
      }

      .review-text {
        font-size: 0.9rem;
      }

      .review-button {
        width: 100%;
        min-width: 0;
      }
    }
  </style>

  <main class="review-page">
    <section class="review-hero">
      <div class="container review-shell">
        <div class="review-showcase">
          <div class="review-panel" aria-hidden="true"></div>
          <div class="review-orbit-line" aria-hidden="true">
            {Array.from({ length: 12 }, (_, index) => <span style={`--dot-index:${index};`}></span>)}
          </div>

          <div class="review-testimonials" aria-label="Customer review highlights">
            {
              reviews.map((review) => (
                <article class="review-mini-card" style={`--review-angle:${review.angle}deg;`}>
                  <div class="review-mini-card-inner">
                    <div class="review-mini-avatar" aria-hidden="true">
                      <img src={review.avatarSrc} alt="" loading="lazy" />
                    </div>
                    <div class="review-mini-body">
                      <div class="review-mini-topline">
                        <h2>{review.name}</h2>
                        <span class="review-google-mark" aria-hidden="true">
                          <svg viewBox="0 0 24 24" focusable="false">
                            <path fill="#4285f4" d="M22.6 12.23c0-.78-.07-1.53-.2-2.23H12v4.26h5.95a5.1 5.1 0 0 1-2.2 3.35v2.78h3.56c2.09-1.92 3.29-4.75 3.29-8.16Z"></path>
                            <path fill="#34a853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.56-2.78c-.99.66-2.25 1.05-3.72 1.05-2.86 0-5.29-1.93-6.16-4.53H2.18v2.86A11 11 0 0 0 12 23Z"></path>
                            <path fill="#fbbc05" d="M5.84 14.08A6.6 6.6 0 0 1 5.49 12c0-.72.12-1.42.35-2.08V7.06H2.18A11 11 0 0 0 1 12c0 1.78.43 3.46 1.18 4.94l3.66-2.86Z"></path>
                            <path fill="#ea4335" d="M12 5.39c1.62 0 3.07.56 4.22 1.65l3.14-3.14C17.46 2.13 14.97 1 12 1A11 11 0 0 0 2.18 7.06l3.66 2.86C6.71 7.32 9.14 5.39 12 5.39Z"></path>
                          </svg>
                        </span>
                      </div>
                      <div class="review-mini-stars" aria-label={`${review.stars} out of 5 stars`}>
                        {Array.from({ length: 5 }, (_, index) => (
                          <span class={index < review.stars ? "" : "review-star-muted"}>★</span>
                        ))}
                      </div>
                      <p>{review.quote}</p>
                    </div>
                  </div>
                </article>
              ))
            }
          </div>

          <article class="review-card">
            <img class="review-logo" src={logo} alt={`${companyName} logo`} />
            <p class="review-brand-label">Velixon</p>

            <div class="review-stars" aria-label="5 out of 5 stars">
              <span>★</span>
              <span>★</span>
              <span>★</span>
              <span>★</span>
              <span>★</span>
            </div>

            <h1>Leave Us <span>a Review</span></h1>
            <p class="review-text">
              If we did a great job for you, we’d really appreciate a quick Google review. It helps our business grow
              and helps other people feel confident working with us.
            </p>

            <div class="review-actions">
              <a
                class="button review-button"
                href="https://g.page/r/CWKplBi6cXafEBE/review"
                target="_blank"
                rel="noopener noreferrer"
              >
                <span class="review-button-google" aria-hidden="true">
                  <svg viewBox="0 0 24 24" focusable="false">
                    <path fill="#4285f4" d="M22.6 12.23c0-.78-.07-1.53-.2-2.23H12v4.26h5.95a5.1 5.1 0 0 1-2.2 3.35v2.78h3.56c2.09-1.92 3.29-4.75 3.29-8.16Z"></path>
                    <path fill="#34a853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.56-2.78c-.99.66-2.25 1.05-3.72 1.05-2.86 0-5.29-1.93-6.16-4.53H2.18v2.86A11 11 0 0 0 12 23Z"></path>
                    <path fill="#fbbc05" d="M5.84 14.08A6.6 6.6 0 0 1 5.49 12c0-.72.12-1.42.35-2.08V7.06H2.18A11 11 0 0 0 1 12c0 1.78.43 3.46 1.18 4.94l3.66-2.86Z"></path>
                    <path fill="#ea4335" d="M12 5.39c1.62 0 3.07.56 4.22 1.65l3.14-3.14C17.46 2.13 14.97 1 12 1A11 11 0 0 0 2.18 7.06l3.66 2.86C6.71 7.32 9.14 5.39 12 5.39Z"></path>
                  </svg>
                </span>
                Leave a Google Review
              </a>
              <p class="review-helper">Takes less than a minute. We really appreciate it.</p>
              <a class="review-secondary-link" href="/contact">Having an issue? Contact us directly</a>
            </div>
          </article>
        </div>
      </div>
    </section>
  </main>
</MainLayout>
