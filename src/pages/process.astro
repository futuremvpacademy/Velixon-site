---
import MainLayout from "../layouts/MainLayout.astro";
import Navbar from "../components/Navbar.astro";
import PageHero from "../components/PageHero.astro";
import ProcessSection from "../components/ProcessSection.astro";
import CardSection from "../components/CardSection.astro";
import FinalCtaSection from "../components/FinalCtaSection.astro";
import { seo, siteContent } from "../data/site";

const { companyName, logo, nav, cta, ctaHref, finalCta, process } = siteContent;
const page = siteContent.pages.process;
---

<MainLayout title={`${seo.title} | Process`} description={seo.description}>
  <Navbar companyName={companyName} logo={logo} nav={nav} cta={cta} currentPath="/process" />
  <main>
    <PageHero
      eyebrow={page.hero.eyebrow}
      title={page.hero.title}
      description={page.hero.description}
      cta={cta}
      ctaHref={ctaHref}
      helper="You’ll always know the next step, what we need, and how the project is moving."
    />
    <ProcessSection process={process} />
    <CardSection
      eyebrow="What to expect"
      title="A process built to keep things moving"
      description="The goal is to keep decisions clear, communication quick, and the path from idea to launch easy to follow."
      items={page.details}
    />
    <FinalCtaSection cta={finalCta} />
  </main>
</MainLayout>
